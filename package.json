{
  "name": "backend-template",
  "version": "1.1.1",
  "description": "Robust and scalable backend server template with NodeJS, TypeScript",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "install:pkg": "pnpm install --frozen-lockfile",
    "preinstall": "npx only-allow pnpm",
    "start": "node --env-file=.env dist/server.js",
    "dev": "tsx watch --clear-screen=false --include './src/**/*' --env-file=.env src/server.ts",
    "dev:node": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"./.path-resolver.mjs\", pathToFileURL(\"./\"));' --watch --env-file=.env src/server.ts",
    "dev:n": "console-ninja pnpm dev",
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --max-warnings 0 --fix",
    "format": "prettier --log-level warn --write \"./**/*.{js,cjs,ts,d.ts,json,yaml,yml,html}\"",
    "test": "vitest run",
    "test:w": "vitest --watch",
    "coverage": "vitest run --coverage",
    "docker": "docker compose up --build -d",
    "docker-stage": "docker compose -f docker-compose.stage.yml up --build -d",
    "docker-dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:sh": "docker exec -it template-server sh",
    "docker-stage:sh": "docker exec -it template-server-stage sh",
    "docker-dev:sh": "docker exec -it template-server-dev sh",
    "redis-cli": "docker exec -it redis redis-cli",
    "lint-staged": "lint-staged",
    "prepare": "husky || true"
  },
  "keywords": [],
  "author": "Saiful Islam Sojib",
  "license": "ISC",
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "multer": "^2.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@stack-lint/base": "^0.2.0",
    "@stack-lint/node": "^0.2.0",
    "@stack-lint/typescript": "^0.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.13.3",
    "@types/supertest": "^7.2.1",
    "@vitest/eslint-plugin": "^1.6.23",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "mongodb-memory-server": "^11.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.1",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11",
    "pnpm": ">=11"
  },
  "lint-staged": {
    "*.{js,cjs,ts,d.ts}": [
      "eslint --max-warnings 0 --fix",
      "vitest related --run"
    ],
    "*.{js,cjs,ts,d.ts,json,yaml,yml,html}": "prettier --log-level warn --write"
  }
}
